PORT=3000

# --- Güvenlik ---
JWT_SECRET=buraya_uzun_ve_rastgele_bir_deger_yaz
JWT_EXPIRES_IN=7d

# --- Veritabanı ---
# Lokal geliştirme: DATABASE_URL boş bırakılırsa SQLite kullanılır.
DATABASE_PATH=data/habitmeet.db
# Production (Railway): PostgreSQL bağlantı adresi.
# DATABASE_URL=postgres://user:pass@host:5432/habitmeet

# --- CORS / Frontend ---
CORS_ORIGIN=http://localhost:5500
FRONTEND_URL=http://localhost:5500

# --- Eşleşme ayarları (soğuk başlangıç: düşük başlat, büyüyünce artır) ---
MIN_STREAK_DAYS=3

# --- Admin seed (ilk açılışta oluşturulur; şifre bcrypt ile saklanır) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=guclu_bir_admin_sifresi

# --- SMTP (boş ise e-postalar konsola yazılır) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=HabitMeet <no-reply@habitmeet.app>

# Rate limit ayarlari (opsiyonel)
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MIN=15
